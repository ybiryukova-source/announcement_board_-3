<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <title>Створити оголошення</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="container form-container">

  <h1>➕ Створити оголошення</h1>

  <form class="announcement-form"
    method="POST"
    action="/announcements">

    <div class="form-group">

      <label>Категорія</label>

      <div class="radio-group">

        <label>
          <input type="radio" name="category" value="sale"
          <%= data.category === 'sale' ? 'checked' : '' %>>
          📦 Продаж
        </label>

        <label>
          <input type="radio" name="category" value="service"
          <%= data.category === 'service' ? 'checked' : '' %>>
          🔧 Послуги
        </label>

        <label>
          <input type="radio" name="category" value="job"
          <%= data.category === 'job' ? 'checked' : '' %>>
          💼 Робота
        </label>

        <label>
          <input type="radio" name="category" value="other"
          <%= data.category === 'other' ? 'checked' : '' %>>
          📌 Інше
        </label>

      </div>

      <% if (errors.category) { %>
        <p class="error"><%= errors.category %></p>
      <% } %>

    </div>

    <div class="form-group">

      <label>Назва</label>

      <input
        type="text"
        name="title"
        placeholder="Коротка назва оголошення"
        required
        minlength="5"
        maxlength="100"
        value="<%= data.title || '' %>"
      >

      <% if (errors.title) { %>
        <p class="error"><%= errors.title %></p>
      <% } %>

    </div>

    <div class="form-group">

      <label>Опис</label>

      <textarea
        name="description"
        rows="6"
        placeholder="Детальний опис..."
        required
        minlength="10"
      ><%= data.description || '' %></textarea>

      <% if (errors.description) { %>
        <p class="error"><%= errors.description %></p>
      <% } %>

    </div>

    <div class="form-group">

      <label>Ціна</label>

      <input
        type="number"
        name="price"
        min="0"
        step="0.01"
        required
        value="<%= data.price || '' %>"
      >

      <% if (errors.price) { %>
        <p class="error"><%= errors.price %></p>
      <% } %>

    </div>

    <div class="form-group">

      <label>Контакти</label>

      <input
        type="text"
        name="contactInfo"
        placeholder="Email або телефон"
        required
        minlength="5"
        value="<%= data.contactInfo || '' %>"
      >

      <% if (errors.contactInfo) { %>
        <p class="error"><%= errors.contactInfo %></p>
      <% } %>

    </div>

    <div class="form-buttons">
      <button type="submit">Опублікувати</button>

      <a class="cancel-btn" href="/">
        Скасувати
      </a>
    </div>

  </form>

</div>

</body>
</html>